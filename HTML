<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>LOGOS Governance Sandbox — AI-GOV-STD-001 Interactive</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Barlow:wght@300;400;600;700;900&family=Barlow+Condensed:wght@700;900&display=swap" rel="stylesheet">
<style>
  :root {
    --black: #050608;
    --deep: #0a0c10;
    --panel: #0f1218;
    --border: #1a2030;
    --border-bright: #2a3550;
    --text: #c8d4e8;
    --text-dim: #5a6a85;
    --text-muted: #2a3550;
    --accent: #00e5ff;
    --accent-dim: #007a8a;
    --warn: #ff9500;
    --danger: #ff3b3b;
    --safe: #00ff88;
    --safe-dim: #00a855;
    --gold: #ffd700;
    --mono: 'Share Tech Mono', monospace;
    --sans: 'Barlow', sans-serif;
    --condensed: 'Barlow Condensed', sans-serif;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background: var(--black);
    color: var(--text);
    font-family: var(--sans);
    font-size: 15px;
    line-height: 1.6;
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* GRID BACKGROUND */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image:
      linear-gradient(rgba(0,229,255,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0,229,255,0.03) 1px, transparent 1px);
    background-size: 40px 40px;
    pointer-events: none;
    z-index: 0;
  }

  /* SCAN LINE */
  body::after {
    content: '';
    position: fixed;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--accent), transparent);
    animation: scanline 8s linear infinite;
    pointer-events: none;
    z-index: 100;
    opacity: 0.4;
  }
  @keyframes scanline { 0% { top: 0; } 100% { top: 100vh; } }

  /* LAYOUT */
  .container {
    position: relative;
    z-index: 1;
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 24px;
  }

  /* HEADER */
  header {
    border-bottom: 1px solid var(--border);
    padding: 20px 0;
    position: sticky;
    top: 0;
    background: rgba(5,6,8,0.95);
    backdrop-filter: blur(10px);
    z-index: 50;
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
  }

  .logo-block {
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .logo-mark {
    width: 40px;
    height: 40px;
    border: 2px solid var(--accent);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--condensed);
    font-weight: 900;
    font-size: 16px;
    color: var(--accent);
    letter-spacing: 1px;
    position: relative;
    clip-path: polygon(10% 0%, 90% 0%, 100% 10%, 100% 90%, 90% 100%, 10% 100%, 0% 90%, 0% 10%);
  }

  .logo-text {
    font-family: var(--condensed);
    font-weight: 900;
    font-size: 20px;
    letter-spacing: 2px;
    color: #fff;
    text-transform: uppercase;
  }

  .logo-sub {
    font-family: var(--mono);
    font-size: 10px;
    color: var(--accent-dim);
    letter-spacing: 1px;
  }

  .header-badges {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .badge {
    font-family: var(--mono);
    font-size: 10px;
    padding: 3px 8px;
    border: 1px solid;
    letter-spacing: 1px;
    text-transform: uppercase;
  }
  .badge-public { border-color: var(--safe-dim); color: var(--safe); }
  .badge-patent { border-color: var(--accent-dim); color: var(--accent); }
  .badge-v { border-color: var(--border-bright); color: var(--text-dim); }

  /* HERO */
  .hero {
    padding: 60px 0 40px;
    border-bottom: 1px solid var(--border);
  }

  .hero-label {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--accent);
    letter-spacing: 3px;
    text-transform: uppercase;
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .hero-label::before {
    content: '';
    display: block;
    width: 30px;
    height: 1px;
    background: var(--accent);
  }

  h1 {
    font-family: var(--condensed);
    font-weight: 900;
    font-size: clamp(36px, 6vw, 72px);
    line-height: 0.95;
    text-transform: uppercase;
    color: #fff;
    margin-bottom: 20px;
  }

  h1 span { color: var(--accent); }

  .hero-desc {
    max-width: 620px;
    color: var(--text-dim);
    font-size: 15px;
    line-height: 1.7;
    margin-bottom: 30px;
  }

  .hero-desc strong { color: var(--text); }

  .hero-stats {
    display: flex;
    gap: 40px;
    flex-wrap: wrap;
  }

  .stat {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .stat-num {
    font-family: var(--condensed);
    font-weight: 900;
    font-size: 28px;
    color: var(--accent);
    line-height: 1;
  }
  .stat-label {
    font-family: var(--mono);
    font-size: 10px;
    color: var(--text-dim);
    letter-spacing: 1px;
    text-transform: uppercase;
  }

  /* MAIN GRID */
  .main-grid {
    display: grid;
    grid-template-columns: 1fr 340px;
    gap: 24px;
    padding: 32px 0;
    align-items: start;
  }

  @media (max-width: 800px) {
    .main-grid { grid-template-columns: 1fr; }
  }

  /* PANEL */
  .panel {
    background: var(--panel);
    border: 1px solid var(--border);
    position: relative;
  }

  .panel::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--accent), transparent);
  }

  .panel-header {
    padding: 14px 20px;
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .panel-title {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--accent);
    letter-spacing: 2px;
    text-transform: uppercase;
  }

  .panel-status {
    font-family: var(--mono);
    font-size: 10px;
    color: var(--text-dim);
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--safe);
    animation: pulse 2s ease-in-out infinite;
  }
  .dot.warn { background: var(--warn); }
  .dot.idle { background: var(--text-muted); animation: none; }
  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  .panel-body { padding: 20px; }

  /* API KEY */
  .api-section {
    margin-bottom: 20px;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--border);
  }

  .field-label {
    font-family: var(--mono);
    font-size: 10px;
    color: var(--text-dim);
    letter-spacing: 1px;
    text-transform: uppercase;
    margin-bottom: 8px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .field-note {
    color: var(--text-muted);
    font-size: 9px;
  }

  input[type="password"], input[type="text"], textarea, select {
    width: 100%;
    background: var(--deep);
    border: 1px solid var(--border);
    color: var(--text);
    font-family: var(--mono);
    font-size: 12px;
    padding: 10px 14px;
    outline: none;
    transition: border-color 0.2s;
    resize: none;
  }

  input:focus, textarea:focus, select:focus {
    border-color: var(--accent-dim);
  }

  input::placeholder, textarea::placeholder {
    color: var(--text-muted);
  }

  /* MODE SELECTOR */
  .mode-selector {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
    margin-bottom: 20px;
  }

  .mode-btn {
    background: var(--deep);
    border: 1px solid var(--border);
    color: var(--text-dim);
    font-family: var(--mono);
    font-size: 10px;
    padding: 10px 8px;
    cursor: pointer;
    text-align: center;
    letter-spacing: 1px;
    text-transform: uppercase;
    transition: all 0.2s;
    position: relative;
  }

  .mode-btn:hover {
    border-color: var(--accent-dim);
    color: var(--text);
  }

  .mode-btn.active {
    background: rgba(0,229,255,0.08);
    border-color: var(--accent);
    color: var(--accent);
  }

  .mode-btn.active::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 2px;
    background: var(--accent);
  }

  .mode-icon { font-size: 14px; display: block; margin-bottom: 3px; }

  /* SCENARIO PRESETS */
  .presets {
    margin-bottom: 16px;
  }

  .preset-grid {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .preset-btn {
    background: var(--deep);
    border: 1px solid var(--border);
    color: var(--text-dim);
    font-family: var(--mono);
    font-size: 10px;
    padding: 8px 12px;
    cursor: pointer;
    text-align: left;
    transition: all 0.2s;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .preset-btn:hover {
    border-color: var(--warn);
    color: var(--text);
  }

  .preset-tag {
    font-size: 9px;
    padding: 2px 5px;
    border: 1px solid var(--warn);
    color: var(--warn);
    flex-shrink: 0;
  }

  /* INPUT AREA */
  .input-area {
    margin-bottom: 16px;
  }

  textarea {
    min-height: 120px;
    line-height: 1.6;
  }

  .char-count {
    font-family: var(--mono);
    font-size: 10px;
    color: var(--text-muted);
    text-align: right;
    margin-top: 4px;
  }

  /* SUBMIT */
  .submit-btn {
    width: 100%;
    background: transparent;
    border: 1px solid var(--accent);
    color: var(--accent);
    font-family: var(--condensed);
    font-weight: 700;
    font-size: 14px;
    letter-spacing: 3px;
    text-transform: uppercase;
    padding: 14px;
    cursor: pointer;
    transition: all 0.2s;
    position: relative;
    overflow: hidden;
  }

  .submit-btn::before {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--accent);
    transform: translateX(-100%);
    transition: transform 0.3s ease;
    z-index: -1;
  }

  .submit-btn:hover {
    color: var(--black);
    background: var(--accent);
  }

  .submit-btn:disabled {
    border-color: var(--border);
    color: var(--text-muted);
    cursor: not-allowed;
    background: transparent;
  }

  /* LAYER STACK - SIDEBAR */
  .layer-stack {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .layer {
    border-bottom: 1px solid var(--border);
    padding: 12px 20px;
    display: flex;
    align-items: center;
    gap: 12px;
    transition: background 0.3s;
  }

  .layer:last-child { border-bottom: none; }

  .layer.active { background: rgba(0,229,255,0.05); }
  .layer.blocked { background: rgba(255,59,59,0.05); }
  .layer.passed { background: rgba(0,255,136,0.03); }

  .layer-id {
    font-family: var(--mono);
    font-size: 10px;
    color: var(--text-muted);
    width: 28px;
    flex-shrink: 0;
  }

  .layer-name {
    flex: 1;
    font-family: var(--mono);
    font-size: 11px;
    color: var(--text-dim);
  }

  .layer.active .layer-name { color: var(--accent); }
  .layer.blocked .layer-name { color: var(--danger); }
  .layer.passed .layer-name { color: var(--safe-dim); }

  .layer-indicator {
    width: 8px;
    height: 8px;
    border: 1px solid var(--text-muted);
    flex-shrink: 0;
  }

  .layer.active .layer-indicator {
    border-color: var(--accent);
    background: var(--accent);
    animation: pulse 1s ease-in-out infinite;
  }
  .layer.blocked .layer-indicator {
    border-color: var(--danger);
    background: var(--danger);
  }
  .layer.passed .layer-indicator {
    border-color: var(--safe-dim);
    background: var(--safe-dim);
  }

  /* DRS METER */
  .drs-section {
    padding: 20px;
    border-top: 1px solid var(--border);
  }

  .drs-label {
    font-family: var(--mono);
    font-size: 10px;
    color: var(--text-dim);
    letter-spacing: 1px;
    margin-bottom: 10px;
    display: flex;
    justify-content: space-between;
  }

  .drs-score {
    font-family: var(--condensed);
    font-weight: 900;
    font-size: 36px;
    line-height: 1;
    color: var(--safe);
    transition: color 0.5s;
  }

  .drs-score.medium { color: var(--warn); }
  .drs-score.high { color: var(--danger); }

  .drs-bar {
    height: 6px;
    background: var(--border);
    margin: 10px 0;
    position: relative;
    overflow: hidden;
  }

  .drs-fill {
    height: 100%;
    width: 0%;
    background: linear-gradient(90deg, var(--safe), var(--warn), var(--danger));
    transition: width 1s ease;
  }

  .drs-mode {
    font-family: var(--mono);
    font-size: 10px;
    color: var(--text-dim);
    letter-spacing: 1px;
    text-transform: uppercase;
  }

  /* RESULTS AREA */
  .results-area {
    min-height: 400px;
  }

  /* LAYER RESULT CARDS */
  .result-card {
    border: 1px solid var(--border);
    margin-bottom: 12px;
    opacity: 0;
    transform: translateY(10px);
    transition: all 0.4s ease;
    position: relative;
    overflow: hidden;
  }

  .result-card.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .result-card.card-block { border-color: rgba(255,59,59,0.4); }
  .result-card.card-warn { border-color: rgba(255,149,0,0.4); }
  .result-card.card-pass { border-color: rgba(0,255,136,0.2); }

  .result-card::before {
    content: '';
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 3px;
  }
  .result-card.card-block::before { background: var(--danger); }
  .result-card.card-warn::before { background: var(--warn); }
  .result-card.card-pass::before { background: var(--safe-dim); }

  .result-card-header {
    padding: 10px 16px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-bottom: 1px solid var(--border);
  }

  .result-layer-name {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--text);
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .result-decision {
    font-family: var(--mono);
    font-size: 10px;
    padding: 3px 8px;
    font-weight: 700;
    letter-spacing: 1px;
  }

  .decision-block { background: rgba(255,59,59,0.15); color: var(--danger); border: 1px solid rgba(255,59,59,0.3); }
  .decision-warn { background: rgba(255,149,0,0.15); color: var(--warn); border: 1px solid rgba(255,149,0,0.3); }
  .decision-pass { background: rgba(0,255,136,0.1); color: var(--safe); border: 1px solid rgba(0,255,136,0.2); }
  .decision-escalate { background: rgba(255,215,0,0.1); color: var(--gold); border: 1px solid rgba(255,215,0,0.3); }

  .result-card-body {
    padding: 14px 16px;
    font-size: 13px;
    color: var(--text-dim);
    line-height: 1.7;
  }

  .result-card-body strong { color: var(--text); }

  .result-meta {
    padding: 8px 16px;
    border-top: 1px solid var(--border);
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }

  .meta-item {
    font-family: var(--mono);
    font-size: 10px;
    color: var(--text-muted);
  }

  .meta-item span { color: var(--text-dim); }

  /* FINAL VERDICT */
  .verdict {
    border: 1px solid;
    padding: 20px;
    margin-top: 16px;
    position: relative;
    opacity: 0;
    transform: translateY(10px);
    transition: all 0.5s ease 0.3s;
  }

  .verdict.visible { opacity: 1; transform: translateY(0); }

  .verdict.verdict-block { border-color: var(--danger); background: rgba(255,59,59,0.05); }
  .verdict.verdict-warn { border-color: var(--warn); background: rgba(255,149,0,0.05); }
  .verdict.verdict-pass { border-color: var(--safe-dim); background: rgba(0,255,136,0.03); }
  .verdict.verdict-escalate { border-color: var(--gold); background: rgba(255,215,0,0.03); }

  .verdict-title {
    font-family: var(--condensed);
    font-weight: 900;
    font-size: 22px;
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-bottom: 8px;
  }

  .verdict-block .verdict-title { color: var(--danger); }
  .verdict-warn .verdict-title { color: var(--warn); }
  .verdict-pass .verdict-title { color: var(--safe); }
  .verdict-escalate .verdict-title { color: var(--gold); }

  .verdict-body {
    font-size: 13px;
    color: var(--text-dim);
    line-height: 1.7;
    margin-bottom: 12px;
  }

  .verdict-drs {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--text-dim);
  }

  /* LOG STRIP */
  .log-strip {
    background: var(--deep);
    border: 1px solid var(--border);
    border-top: 2px solid var(--accent-dim);
    padding: 14px 20px;
    margin-top: 24px;
    font-family: var(--mono);
    font-size: 10px;
    color: var(--text-muted);
    max-height: 120px;
    overflow-y: auto;
  }

  .log-line {
    padding: 2px 0;
    display: flex;
    gap: 12px;
  }

  .log-time { color: var(--accent-dim); flex-shrink: 0; }
  .log-msg { color: var(--text-dim); }
  .log-msg.err { color: var(--danger); }
  .log-msg.ok { color: var(--safe-dim); }
  .log-msg.warn { color: var(--warn); }

  /* EMPTY STATE */
  .empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 300px;
    gap: 16px;
    color: var(--text-muted);
    text-align: center;
  }

  .empty-icon {
    font-size: 48px;
    opacity: 0.3;
  }

  .empty-title {
    font-family: var(--condensed);
    font-weight: 700;
    font-size: 18px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .empty-sub {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--text-muted);
    max-width: 280px;
  }

  /* LOADING */
  .loading {
    display: none;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 200px;
    gap: 20px;
  }

  .loading.active { display: flex; }

  .loading-ring {
    width: 48px;
    height: 48px;
    border: 2px solid var(--border);
    border-top-color: var(--accent);
    border-radius: 50%;
    animation: spin 1s linear infinite;
  }
  @keyframes spin { to { transform: rotate(360deg); } }

  .loading-text {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--text-dim);
    letter-spacing: 2px;
    text-transform: uppercase;
  }

  .loading-layer {
    font-family: var(--mono);
    font-size: 10px;
    color: var(--accent);
    letter-spacing: 1px;
  }

  /* INTERACTION COUNTER */
  .counter-strip {
    background: var(--deep);
    border-top: 1px solid var(--border);
    padding: 12px 0;
  }

  .counter-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    flex-wrap: wrap;
  }

  .counter-item {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--mono);
    font-size: 10px;
    color: var(--text-muted);
  }

  .counter-num {
    font-family: var(--condensed);
    font-weight: 700;
    font-size: 16px;
    color: var(--accent);
  }

  /* FOOTER */
  footer {
    border-top: 1px solid var(--border);
    padding: 24px 0;
    margin-top: 40px;
  }

  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    flex-wrap: wrap;
  }

  .footer-text {
    font-family: var(--mono);
    font-size: 10px;
    color: var(--text-muted);
    line-height: 1.8;
  }

  .footer-links {
    display: flex;
    gap: 16px;
  }

  .footer-links a {
    font-family: var(--mono);
    font-size: 10px;
    color: var(--accent-dim);
    text-decoration: none;
    letter-spacing: 1px;
    text-transform: uppercase;
  }

  .footer-links a:hover { color: var(--accent); }

  /* NOTICE BANNER */
  .notice {
    background: rgba(0,229,255,0.05);
    border: 1px solid var(--accent-dim);
    padding: 10px 16px;
    margin-bottom: 20px;
    font-family: var(--mono);
    font-size: 11px;
    color: var(--text-dim);
    display: flex;
    align-items: flex-start;
